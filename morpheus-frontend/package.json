{
  "name": "morpheus-app",
  "version": "1.0.0",
  "description": "A full-stack analytics platform for data processing, visualization, and insights generation",
  "private": true,
  "workspaces": [
    "frontend"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "cd ../morpheus-backend && python -m app.main",
    "build": "cd frontend && npm run build",
    "install:all": "npm install && cd frontend && npm install",
    "lint": "cd frontend && npm run lint",
    "test": "cd ../morpheus-backend && pytest",
    "format": "cd ../morpheus-backend && black .",
    "clean": "rm -rf frontend/node_modules frontend/dist ../morpheus-backend/__pycache__"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "keywords": [
    "analytics",
    "data-visualization",
    "react",
    "typescript",
    "python",
    "fastapi"
  ],
  "author": "Morpheus App Team",
  "license": "MIT",
  "dependencies": {
    "@clerk/themes": "^2.4.19",
    "lightswind": "^3.1.16",
    "radix-ui": "^1.4.3",
    "react-textarea-autosize": "^8.5.9",
    "zustand": "^5.0.8"
  }
}
